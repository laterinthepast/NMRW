{
  "backend": {
    "name": "github",
    "repo": "laterinthepast/NMRW",
    "branch": "main",
    "base_url": "https://nmrw-4tmo.vercel.app"
  },
  "media_folder": "sites/anchor-cleaver/images",
  "public_folder": "/images",
  "collections": [
    {
      "name": "settings",
      "label": "Site Settings",
      "files": [
        {
          "label": "Contact & Hours",
          "name": "settings",
          "file": "sites/anchor-cleaver/content/settings.json",
          "format": "json",
          "fields": [
            { "label": "Address Line 1", "name": "address_line1", "widget": "string" },
            { "label": "Address Line 2", "name": "address_line2", "widget": "string" },
            { "label": "Postcode", "name": "address_postcode", "widget": "string" },
            { "label": "Phone Number", "name": "phone", "widget": "string" },
            { "label": "Email Address", "name": "email", "widget": "string" },
            { "label": "Hours — Mon to Thu", "name": "hours_mon_thu", "widget": "string" },
            { "label": "Hours — Fri & Sat", "name": "hours_fri_sat", "widget": "string" },
            { "label": "Hours — Sunday", "name": "hours_sun", "widget": "string" },
            { "label": "Kitchen Closes", "name": "hours_kitchen", "widget": "string" },
            { "label": "Google Maps URL", "name": "google_maps_url", "widget": "string" }
          ]
        }
      ]
    },
    {
      "name": "events",
      "label": "Events",
      "files": [
        {
          "label": "Upcoming Events",
          "name": "events",
          "file": "sites/anchor-cleaver/content/events.json",
          "format": "json",
          "fields": [
            {
              "label": "Events",
              "name": "events",
              "widget": "list",
              "fields": [
                { "label": "Day (number only, e.g. 12)", "name": "day", "widget": "string" },
                { "label": "Month (e.g. Apr)", "name": "month", "widget": "string" },
                { "label": "Event Title", "name": "title", "widget": "string" },
                { "label": "Description", "name": "description", "widget": "text" },
                { "label": "Time", "name": "time", "widget": "string" }
              ]
            }
          ]
        }
      ]
    },
    {
      "name": "menu",
      "label": "Menu",
      "files": [
        {
          "label": "Food, Drinks & Sunday Menu",
          "name": "menu",
          "file": "sites/anchor-cleaver/content/menu.json",
          "format": "json",
          "fields": [
            {
              "label": "Food Menu",
              "name": "food",
              "widget": "list",
              "fields": [
                { "label": "Dish Name", "name": "name", "widget": "string" },
                { "label": "Price (e.g. £8.50)", "name": "price", "widget": "string" },
                { "label": "Description", "name": "description", "widget": "text" },
                { "label": "Tag", "name": "tag", "widget": "select", "options": ["Starter", "Main", "Dessert", "Special"] }
              ]
            },
            {
              "label": "Drinks Menu",
              "name": "drinks",
              "widget": "list",
              "fields": [
                { "label": "Drink Name", "name": "name", "widget": "string" },
                { "label": "Price (e.g. £5.00)", "name": "price", "widget": "string" },
                { "label": "Description", "name": "description", "widget": "text" },
                { "label": "Tag", "name": "tag", "widget": "select", "options": ["Lager", "Ale", "Stout", "Wine", "Spirits", "Soft"] }
              ]
            },
            {
              "label": "Sunday Menu",
              "name": "sunday",
              "widget": "list",
              "fields": [
                { "label": "Dish Name", "name": "name", "widget": "string" },
                { "label": "Price (e.g. £16.00)", "name": "price", "widget": "string" },
                { "label": "Description", "name": "description", "widget": "text" },
                { "label": "Tag", "name": "tag", "widget": "select", "options": ["Starter", "Main", "Dessert"] }
              ]
            }
          ]
        }
      ]
    }
  ]
}
