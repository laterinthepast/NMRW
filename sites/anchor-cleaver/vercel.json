{
  "version": 2,
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" },
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "admin/**", "use": "@vercel/static" },
    { "src": "content/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/auth", "dest": "/api/auth.js" },
    { "src": "/callback", "dest": "/api/callback.js" },
    { "src": "/api/auth", "dest": "/api/auth.js" },
    { "src": "/api/callback", "dest": "/api/callback.js" },
    { "src": "/api/auth/callback", "dest": "/api/callback.js" },
    { "src": "/admin/?$", "dest": "/admin/index.html" },
    { "src": "/admin/(.+)", "dest": "/admin/$1" },
    { "src": "/content/(.+)", "dest": "/content/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
